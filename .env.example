# Copy to .env and fill in. .env is gitignored — never commit real values.

# Neo4j password (also becomes the neo4j container's auth).
NEO4J_PASSWORD=change-me

# Static bearer token for the query API. Generate something long and random:
#   openssl rand -hex 32
# The web proxy injects it server-side; MCP users set the same value as
# QUERY_AUTH_TOKEN in their Claude Code MCP config.
QUERY_AUTH_TOKEN=change-me

# Read-only GitHub credential for cloning private repos over https
# (fine-grained PAT with Contents:read, or a GitHub App installation token).
# Leave empty if repos.yaml uses file:// or public URLs, or if you mount SSH
# keys into the indexer instead.
GITHUB_TOKEN=

# How often the indexer re-checks every repo. Cycles are cheap (unchanged
# HEADs are skipped after one git fetch), so keep this well under the 24h
# freshness SLA for retry headroom.
INDEX_INTERVAL=1h

# Host port for the web portal.
WEB_PORT=80
