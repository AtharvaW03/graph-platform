# Copy to .env (compose reads it automatically) and fill in real values.
# Never commit the real .env.

# Required. Becomes NEO4J_AUTH=neo4j/${NEO4J_PASSWORD} for the neo4j
# container and NEO4J_PASSWORD for query-service/indexer.
NEO4J_PASSWORD=changeme

# Optional. Bearer token query-service requires on every route but /health.
# Empty disables auth. The web container injects this into the Authorization
# header server-side (nginx) - it is never shipped in the JS bundle.
QUERY_AUTH_TOKEN=

# Optional. Bearer token the hosted mcp-server requires on incoming MCP
# connections (/health stays open). Separate from QUERY_AUTH_TOKEN: this one
# is distributed to every engineer's Claude Code config, that one never
# leaves the deployment. Empty disables auth (loud warning at startup).
MCP_AUTH_TOKEN=

# Optional. GitHub PAT for the indexer to clone private repos over HTTPS.
# Public repos work with this unset. Ignored if the GITHUB_APP_* vars below
# are set - GitHub App auth takes precedence when configured.
GIT_TOKEN=

# Optional, all three together. GitHub App auth for the indexer, preferred
# over GIT_TOKEN where available (short-lived installation tokens instead of
# a long-lived PAT). Leave all three empty to use GIT_TOKEN instead.
GITHUB_APP_ID=
GITHUB_APP_INSTALLATION_ID=
GITHUB_APP_PRIVATE_KEY_PATH=
