# Copy to .env (compose reads it automatically) and fill in real values.
# Never commit the real .env.

# Required. Becomes NEO4J_AUTH=neo4j/${NEO4J_PASSWORD} for the neo4j
# container and NEO4J_PASSWORD for query-service/indexer.
NEO4J_PASSWORD=changeme

# Optional. Bearer token query-service requires on every route but /health.
# Empty disables auth. The web container injects this into the Authorization
# header server-side (nginx) - it is never shipped in the JS bundle.
QUERY_AUTH_TOKEN=

# Optional. GitHub PAT for the indexer to clone private repos over HTTPS.
# Public repos work with this unset.
GIT_TOKEN=
