# Build the static bundle
FROM node:22-alpine AS build
WORKDIR /web
COPY web/package.json web/package-lock.json ./
RUN npm ci
COPY web/ .
RUN npm run build

# Serve via Caddy: static files + /api reverse proxy that injects the
# Authorization header SERVER-SIDE. The bearer token never reaches the
# browser — this is the deployment model web/src/api.ts documents.
FROM caddy:2-alpine
COPY deploy/Caddyfile /etc/caddy/Caddyfile
COPY --from=build /web/dist /srv
