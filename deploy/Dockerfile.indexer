# Build stage
FROM golang:1.26 AS build
WORKDIR /src
COPY go.mod go.sum ./
RUN go mod download
COPY cmd ./cmd
COPY internal ./internal
RUN CGO_ENABLED=0 go build -trimpath -o /out/indexer ./cmd/indexer

# Runtime: needs python (graphify), git, and ssh for cloning.
# graphify's `update` mode is AST-only — it makes no LLM API calls, so the
# container needs no AI credentials and no code ever leaves it except to
# fetch from GitHub.
FROM python:3.12-slim
RUN apt-get update \
    && apt-get install -y --no-install-recommends git openssh-client ca-certificates \
    && rm -rf /var/lib/apt/lists/* \
    && pip install --no-cache-dir graphifyy

COPY --from=build /out/indexer /usr/local/bin/indexer
COPY deploy/indexer-entrypoint.sh /usr/local/bin/indexer-entrypoint.sh
RUN chmod +x /usr/local/bin/indexer-entrypoint.sh

# Clones, graphify outputs, and state.json live here; mount a volume so
# incremental indexing survives container restarts.
VOLUME /workdir
WORKDIR /app

ENTRYPOINT ["/usr/local/bin/indexer-entrypoint.sh"]
