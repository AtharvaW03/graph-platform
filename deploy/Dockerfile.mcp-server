# Build context: repo root. docker build -f deploy/Dockerfile.mcp-server .
FROM golang:1.26.4-alpine AS builder
WORKDIR /src
COPY go.mod go.sum ./
RUN go mod download
COPY cmd/mcp-server ./cmd/mcp-server
COPY internal ./internal
RUN CGO_ENABLED=0 GOOS=linux go build -trimpath -o /out/mcp-server ./cmd/mcp-server

FROM gcr.io/distroless/static-debian12:nonroot
COPY --from=builder /out/mcp-server /mcp-server
EXPOSE 8080
ENTRYPOINT ["/mcp-server"]
