# Build context: repo root. docker build -f deploy/Dockerfile.query-service .
FROM golang:1.26.4-alpine AS builder
WORKDIR /src
COPY go.mod go.sum ./
RUN go mod download
COPY cmd/query-service ./cmd/query-service
COPY internal ./internal
RUN CGO_ENABLED=0 GOOS=linux go build -trimpath -o /out/query-service ./cmd/query-service

FROM gcr.io/distroless/static-debian12:nonroot
COPY --from=builder /out/query-service /query-service
EXPOSE 8080
ENTRYPOINT ["/query-service"]
